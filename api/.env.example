# Node/App Environment - development, test or production
NODE_ENV=

# Application http port - 3333
PORT=

# JWT Secret key - string with min 20 chars 
JWT_SECRET=

# Database connection string - "mysql://root:docker123@localhost:3306/gympass-db"
DATABASE_URL=

# Allowed CORS origins, comma-separated (prod only) - "https://app.com,https://admin.app.com"
CORS_ORIGIN=

# Minimum password length on registration (8 to 72) - "8"
PASSWORD_MIN_LENGTH=8

# Password complexity (regex). Length comes from PASSWORD_MIN_LENGTH above.
# Examples:
#   upper/lower/number/special: ^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).+$
#   upper/lower/number:         ^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).+$
PASSWORD_PATTERN=^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).+$

# Minimum length for text "name-of-things" fields: username, gym title, search
# query. Floor of 3 (boot fails if lower) - "3"
MIN_TEXT_LENGTH=3

# Maximum request body size, in bytes - "16384"
BODY_LIMIT=16384

# Log level - fatal, error, warn, info, debug, trace or silent
LOG_LEVEL=info

# Error reporting (optional, future) - Sentry DSN
# SENTRY_DSN=

# Trust the X-Forwarded-For header from a reverse proxy.
# Set to 'true' or a specific proxy IP when behind Nginx/Cloudflare/ALB.
# Without this, request.ip returns the proxy IP and rate-limiting per IP is useless.
TRUST_PROXY=false

# Under-pressure thresholds — returns 503 when exceeded.
# Event-loop lag in milliseconds before returning 503 (default: 1000)
MAX_EVENT_LOOP_DELAY=1000
# Heap size in bytes before returning 503 (default: 209715200 = 200 MB)
MAX_HEAP_USED_BYTES=209715200

# Login lockout settings
# Number of failed login attempts before an account is locked (default: 5)
LOGIN_MAX_ATTEMPTS=5
# How long (in minutes) a locked account stays locked (default: 15)
LOGIN_LOCKOUT_MINUTES=15

# Email links (verification + password reset)
# Base URL prefixed to the verify-email AND reset-password links the email
# provider sends. Point it at your frontend/SPA origin so those links open the
# app's pages (e.g. http://localhost:3001 in dev) — the SPA then calls the
# backend. Leave it on the backend only if there is no frontend. Note the
# reset-password link has no backend GET page, so it requires a frontend route.
# Default: http://localhost:3333
APP_URL=http://localhost:3333
# Email verification token/OTP validity in hours (default: 24)
VERIFICATION_EXPIRES_HOURS=24
# Block protected routes for unverified users (default: false)
REQUIRE_EMAIL_VERIFICATION=false

# Password reset settings
# Password-reset token/OTP validity in minutes (default: 60)
RESET_EXPIRES_MINUTES=60

# ADMIN seed credentials (consumed by "pnpm seeddb")
# Username: 3-30 chars, letters/numbers/underscore only, stored lowercase
ADMIN_USERNAME=
ADMIN_EMAIL=
# Min 10 chars, with an uppercase, a lowercase, a number and a special character - "Admin@12345"
ADMIN_PASSWORD=