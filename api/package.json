{
  "name": "solid_api_sample",
  "version": "1.0.0",
  "description": "GymPass style API using SOLID standards",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "compile": "pnpm exec tsc",
    "build": "tsup",
    "start": "node build/server.mjs",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "check": "prettier --check \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "compose:up": "docker compose up -d",
    "compose:stop": "docker compose stop",
    "compose:down": "docker compose down",
    "migrate": "pnpm exec prisma migrate dev",
    "showdb": "pnpm exec prisma studio --port 5555 --browser none",
    "seeddb": "pnpm exec prisma db seed",
    "db:fresh": "pnpm compose:down && docker compose up -d --wait && pnpm exec prisma migrate deploy && pnpm seeddb",
    "killapp": "fuser -k 3333/tcp 5555/tcp 2>/dev/null; pkill -f '[t]sx.*server.ts' 2>/dev/null; pkill -f '[b]uild/server.mjs' 2>/dev/null; echo 'killapp: freed 3333 (app) + 5555 (prisma studio);'",
    "test": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:watch": "vitest --project unit",
    "test:e2e:watch": "vitest --project e2e",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rramires/solid_api_sample.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rramires/solid_api_sample/issues"
  },
  "homepage": "https://github.com/rramires/solid_api_sample#readme",
  "packageManager": "pnpm@11.5.2",
  "dependencies": {
    "@root/contracts": "workspace:*",
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/under-pressure": "^9.0.3",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@types/bcryptjs": "3.0.0",
    "bcryptjs": "3.0.3",
    "dayjs": "1.11.21",
    "dotenv": "17.4.2",
    "fastify": "5.8.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.2",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "4.1.8",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "17.6.0",
    "mysql2": "^3.22.5",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.3",
    "prettier-plugin-curly": "^0.4.1",
    "prisma": "7.8.0",
    "supertest": "7.2.2",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.8"
  }
}
