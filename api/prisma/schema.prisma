// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/prisma-client"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id            String   @id @default(uuid()) @db.VarChar(36)
  username      String   @unique @db.VarChar(30)
  email         String   @unique @db.VarChar(254)
  password_hash String   @db.VarChar(60)
  role          Role     @default(USER)
  is_verified   Boolean  @default(false)
  created_at    DateTime @default(now())
  // Set on every password change. Tokens issued before this instant are
  // rejected (global logout) via the password-changed registry.
  password_changed_at DateTime?

  checkIns            CheckIn[]
  email_verifications EmailVerification[]
  password_resets     PasswordReset[]
  email_changes       EmailChange[]

  @@map("users")
}

model CheckIn {
  id           String    @id @default(uuid())
  created_at   DateTime  @default(now())
  validated_at DateTime?

  user    User   @relation(fields: [user_id], references: [id])
  user_id String @db.VarChar(36)

  gym    Gym    @relation(fields: [gym_id], references: [id])
  gym_id String @db.VarChar(36)

  @@map("check_ins")
}

model Gym {
  id          String  @id @default(uuid()) @db.VarChar(36)
  title       String  @db.VarChar(100)
  description String? @db.VarChar(500)
  phone       String? @db.VarChar(20)
  latitude    Decimal
  longitude   Decimal

  checkIns CheckIn[]

  @@map("gyms")
}

model EmailVerification {
  id         String    @id @default(uuid()) @db.VarChar(36)
  user_id    String    @db.VarChar(36)
  link_token String    @unique @default(uuid())
  otp_code   String
  // Wrong-OTP counter; the record is invalidated once it reaches the cap.
  attempts   Int       @default(0)
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

// Self-service email change (pattern A): the proven address is never
// overwritten until the new one is confirmed. Mirrors EmailVerification, plus
// the pending new_email being confirmed.
model EmailChange {
  id         String    @id @default(uuid()) @db.VarChar(36)
  user_id    String    @db.VarChar(36)
  new_email  String    @db.VarChar(254)
  link_token String    @unique @default(uuid())
  otp_code   String
  // Wrong-OTP counter; the record is invalidated once it reaches the cap.
  attempts   Int       @default(0)
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("email_changes")
}

model PasswordReset {
  id              String    @id @default(uuid()) @db.VarChar(36)
  user_id         String    @db.VarChar(36)
  link_token_hash String    @unique // sha256 hex of the UUID sent by email
  otp_code_hash   String // sha256 hex of the 6-digit code
  attempts        Int       @default(0)
  expires_at      DateTime
  used_at         DateTime?
  created_at      DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model RevokedToken {
  jti        String   @id
  expires_at DateTime
  created_at DateTime @default(now())

  @@map("revoked_tokens")
}
