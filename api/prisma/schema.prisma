// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/prisma-client"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id                  String    @id @default(uuid()) @db.VarChar(36)
  username            String    @unique @db.VarChar(30)
  email               String    @unique @db.VarChar(254)
  password_hash       String    @db.VarChar(60)
  role                Role      @default(USER)
  is_verified         Boolean   @default(false)
  // Deactivated accounts can't log in and are cut off on their next request.
  is_active           Boolean   @default(true)
  // The user's preferred landing screen key (overrides their profile default).
  default_screen_key  String?   @db.VarChar(100)
  created_at          DateTime  @default(now())
  // Set on every password change. Tokens issued before this instant are
  // rejected (global logout) via the password-changed registry.
  password_changed_at DateTime?

  checkIns            CheckIn[]
  email_verifications EmailVerification[]
  password_resets     PasswordReset[]
  email_changes       EmailChange[]
  profiles            UserProfile[]

  @@map("users")
}

// ─── Access control (RBAC) ───────────────────────────────────────────────────
// A module groups screens; a screen owns a curated permission catalog and is the
// unit a profile takes MEMBERSHIP in; a profile bundles membership + granted
// permissions and is assigned to users. Three axes gate access: grant
// (ProfilePermission), kill switch (Screen.is_enabled) and disable (is_active).
// Profiles are global (no tenant) — a cloning project adds company_id here.
model Module {
  id          String  @id @default(uuid()) @db.VarChar(36)
  key         String  @unique @db.VarChar(100)
  name        String  @db.VarChar(100)
  description String? @db.VarChar(500)
  order       Int     @default(0)
  // is_system protects seeded modules (no delete / no key rename); mirrors Profile.
  is_system   Boolean @default(false)
  // Lifecycle (disable): inactive modules are hidden from the "add" pickers
  // below; existing screens keep working.
  is_active   Boolean @default(true)

  screens Screen[]

  @@map("modules")
}

model Screen {
  id          String  @id @default(uuid()) @db.VarChar(36)
  key         String  @unique @db.VarChar(100)
  name        String  @db.VarChar(100)
  path        String? @db.VarChar(200)
  description String? @db.VarChar(500)
  order       Int     @default(0)
  // is_system protects seeded screens (no delete / no key rename); mirrors Profile.
  is_system   Boolean @default(false)
  // Lifecycle (disable): inactive screens are hidden from the "add" pickers;
  // existing memberships keep working until removed by hand.
  is_active   Boolean @default(true)
  // Kill switch (On): when false the screen stops working NOW for all non-admins
  // (emergency) — "This screen is temporarily unavailable."
  is_enabled  Boolean @default(true)

  module_id String @db.VarChar(36)
  // No cascade: a module with screens can't be deleted (use-case 409s first).
  module    Module @relation(fields: [module_id], references: [id], onDelete: Restrict)

  // Membership (which profiles list this screen in their sidebar). No cascade —
  // a screen assigned to a profile can't be deleted (use-case 409s first).
  members     ProfileScreen[]
  // Curated permission catalog this screen offers.
  permissions Permission[]
  // Profiles that land here (Profile.default_screen_id back-reference).
  default_for Profile[]       @relation("ProfileDefaultScreen")

  @@map("screens")
}

model Profile {
  id          String   @id @default(uuid()) @db.VarChar(36)
  key         String   @unique @db.VarChar(100)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  // is_system protects seeded profiles (no delete / no key rename); grants stay
  // editable. is_default is auto-attached to new users on /register.
  is_system   Boolean  @default(false)
  is_default  Boolean  @default(false)
  // Lifecycle (disable): inactive profiles are hidden when assigning profiles to
  // users; existing assignments keep working.
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  // The profile's landing screen (must be an assigned, viewable screen). Replaces
  // the old per-grant is_default flag. SetNull if that screen is ever removed.
  default_screen_id String? @db.VarChar(36)
  default_screen    Screen? @relation("ProfileDefaultScreen", fields: [default_screen_id], references: [id], onDelete: SetNull)

  // Membership + granted permissions (the two M:N halves of a grant).
  screens     ProfileScreen[]
  permissions ProfilePermission[]
  users       UserProfile[]

  @@map("profiles")
}

// Membership: the profile lists this screen (so it shows in the sidebar), even
// with zero granted permissions — staged rollout. `view` is now a real granted
// permission (ProfilePermission), not a column here.
model ProfileScreen {
  profile_id String @db.VarChar(36)
  screen_id  String @db.VarChar(36)

  // Cascade: removing the profile drops its memberships. Restrict on the screen
  // side blocks deleting a screen that's still a member somewhere.
  profile Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  screen  Screen  @relation(fields: [screen_id], references: [id], onDelete: Restrict)

  @@id([profile_id, screen_id])
  @@map("profile_screens")
}

// A curated permission a screen offers: the fixed action + a friendly, editable
// label. is_system mirrors the screen (seeded permissions are protected).
model Permission {
  id        String  @id @default(uuid()) @db.VarChar(36)
  screen_id String  @db.VarChar(36)
  // Free string KEY (the code contract): a bare CRUD family (`create`) or a
  // composed `family_name` (`create_checkin`). Validated app-side by
  // actionKeySchema; the family must be one of view/create/edit/delete.
  action    String  @db.VarChar(191)
  label     String  @db.VarChar(100)
  is_system Boolean @default(false)

  // Cascade: a deletable screen takes its (ungranted) permissions with it.
  screen   Screen              @relation(fields: [screen_id], references: [id], onDelete: Cascade)
  // No cascade: a granted permission can't be deleted (use-case 409s first).
  profiles ProfilePermission[]

  @@unique([screen_id, action])
  @@map("permissions")
}

// A profile granting one permission (the "grant" half). Granted = row exists.
model ProfilePermission {
  profile_id    String @db.VarChar(36)
  permission_id String @db.VarChar(36)

  profile    Profile    @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Restrict)

  @@id([profile_id, permission_id])
  @@map("profile_permissions")
}

model UserProfile {
  user_id    String @db.VarChar(36)
  profile_id String @db.VarChar(36)

  // User delete cascades their assignments; profile delete does NOT — a profile
  // assigned to users can't be deleted (use-case 409s first; this is the net).
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profile_id], references: [id], onDelete: Restrict)

  @@id([user_id, profile_id])
  @@map("user_profiles")
}

model CheckIn {
  id           String    @id @default(uuid())
  created_at   DateTime  @default(now())
  validated_at DateTime?

  user    User   @relation(fields: [user_id], references: [id])
  user_id String @db.VarChar(36)

  gym    Gym    @relation(fields: [gym_id], references: [id])
  gym_id String @db.VarChar(36)

  @@map("check_ins")
}

model Gym {
  id          String  @id @default(uuid()) @db.VarChar(36)
  title       String  @db.VarChar(100)
  description String? @db.VarChar(500)
  phone       String? @db.VarChar(20)
  latitude    Decimal
  longitude   Decimal
  // Soft-delete: an inactive gym is hidden from members and refuses check-ins;
  // CheckIn.gym_id is a required FK with no cascade, so history is never lost.
  is_active   Boolean @default(true)

  checkIns CheckIn[]

  @@map("gyms")
}

model EmailVerification {
  id         String    @id @default(uuid()) @db.VarChar(36)
  user_id    String    @db.VarChar(36)
  link_token String    @unique @default(uuid())
  otp_code   String
  // Wrong-OTP counter; the record is invalidated once it reaches the cap.
  attempts   Int       @default(0)
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

// Self-service email change (pattern A): the proven address is never
// overwritten until the new one is confirmed. Mirrors EmailVerification, plus
// the pending new_email being confirmed.
model EmailChange {
  id         String    @id @default(uuid()) @db.VarChar(36)
  user_id    String    @db.VarChar(36)
  new_email  String    @db.VarChar(254)
  link_token String    @unique @default(uuid())
  otp_code   String
  // Wrong-OTP counter; the record is invalidated once it reaches the cap.
  attempts   Int       @default(0)
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("email_changes")
}

model PasswordReset {
  id              String    @id @default(uuid()) @db.VarChar(36)
  user_id         String    @db.VarChar(36)
  link_token_hash String    @unique // sha256 hex of the UUID sent by email
  otp_code_hash   String // sha256 hex of the 6-digit code
  attempts        Int       @default(0)
  expires_at      DateTime
  used_at         DateTime?
  created_at      DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model RevokedToken {
  jti        String   @id
  expires_at DateTime
  created_at DateTime @default(now())

  @@map("revoked_tokens")
}

model Notice {
  id         String   @id @default(uuid()) @db.VarChar(36)
  title      String   @db.VarChar(200)
  category   String   @db.VarChar(20)
  created_at DateTime @default(now())

  @@map("notices")
}
