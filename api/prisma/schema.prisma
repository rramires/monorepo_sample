// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/prisma-client"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id            String   @id @default(uuid()) @db.VarChar(36)
  username      String   @unique @db.VarChar(30)
  email         String   @unique @db.VarChar(254)
  password_hash String   @db.VarChar(60)
  role          Role     @default(USER)
  is_verified   Boolean  @default(false)
  // Deactivated accounts can't log in and are cut off on their next request.
  is_active     Boolean  @default(true)
  // The user's preferred landing screen key (overrides their profile default).
  default_screen_key String? @db.VarChar(100)
  created_at    DateTime @default(now())
  // Set on every password change. Tokens issued before this instant are
  // rejected (global logout) via the password-changed registry.
  password_changed_at DateTime?

  checkIns            CheckIn[]
  email_verifications EmailVerification[]
  password_resets     PasswordReset[]
  email_changes       EmailChange[]
  profiles            UserProfile[]

  @@map("users")
}

// ─── Access control (RBAC) ───────────────────────────────────────────────────
// A module groups screens; a screen is the unit grants attach to; a profile
// bundles screen grants (with per-action booleans) and is assigned to users.
// Profiles are global (no tenant) — a cloning project adds company_id here.
model Module {
  id          String  @id @default(uuid()) @db.VarChar(36)
  key         String  @unique @db.VarChar(100)
  name        String  @db.VarChar(100)
  description String? @db.VarChar(500)
  order       Int     @default(0)
  // is_system protects seeded modules (no delete / no key rename); mirrors Profile.
  is_system   Boolean @default(false)

  screens Screen[]

  @@map("modules")
}

model Screen {
  id          String  @id @default(uuid()) @db.VarChar(36)
  key         String  @unique @db.VarChar(100)
  name        String  @db.VarChar(100)
  path        String? @db.VarChar(200)
  description String? @db.VarChar(500)
  order       Int     @default(0)
  // is_system protects seeded screens (no delete / no key rename); mirrors Profile.
  is_system   Boolean @default(false)

  module_id String @db.VarChar(36)
  module    Module @relation(fields: [module_id], references: [id], onDelete: Cascade)

  grants ProfileScreen[]

  @@map("screens")
}

model Profile {
  id          String   @id @default(uuid()) @db.VarChar(36)
  key         String   @unique @db.VarChar(100)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  // is_system protects seeded profiles (no delete / no key rename); grants stay
  // editable. is_default is auto-attached to new users on /register.
  is_system   Boolean  @default(false)
  is_default  Boolean  @default(false)
  created_at  DateTime @default(now())

  screens ProfileScreen[]
  users   UserProfile[]

  @@map("profiles")
}

model ProfileScreen {
  profile_id String  @db.VarChar(36)
  screen_id  String  @db.VarChar(36)
  can_view   Boolean @default(true)
  can_create Boolean @default(false)
  can_edit   Boolean @default(false)
  can_delete Boolean @default(false)
  // At most one grant per profile is the profile's default landing screen.
  is_default Boolean @default(false)

  profile Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  screen  Screen  @relation(fields: [screen_id], references: [id], onDelete: Cascade)

  @@id([profile_id, screen_id])
  @@map("profile_screens")
}

model UserProfile {
  user_id    String @db.VarChar(36)
  profile_id String @db.VarChar(36)

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@id([user_id, profile_id])
  @@map("user_profiles")
}

model CheckIn {
  id           String    @id @default(uuid())
  created_at   DateTime  @default(now())
  validated_at DateTime?

  user    User   @relation(fields: [user_id], references: [id])
  user_id String @db.VarChar(36)

  gym    Gym    @relation(fields: [gym_id], references: [id])
  gym_id String @db.VarChar(36)

  @@map("check_ins")
}

model Gym {
  id          String  @id @default(uuid()) @db.VarChar(36)
  title       String  @db.VarChar(100)
  description String? @db.VarChar(500)
  phone       String? @db.VarChar(20)
  latitude    Decimal
  longitude   Decimal
  // Soft-delete: an inactive gym is hidden from members and refuses check-ins;
  // CheckIn.gym_id is a required FK with no cascade, so history is never lost.
  is_active   Boolean @default(true)

  checkIns CheckIn[]

  @@map("gyms")
}

model EmailVerification {
  id         String    @id @default(uuid()) @db.VarChar(36)
  user_id    String    @db.VarChar(36)
  link_token String    @unique @default(uuid())
  otp_code   String
  // Wrong-OTP counter; the record is invalidated once it reaches the cap.
  attempts   Int       @default(0)
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

// Self-service email change (pattern A): the proven address is never
// overwritten until the new one is confirmed. Mirrors EmailVerification, plus
// the pending new_email being confirmed.
model EmailChange {
  id         String    @id @default(uuid()) @db.VarChar(36)
  user_id    String    @db.VarChar(36)
  new_email  String    @db.VarChar(254)
  link_token String    @unique @default(uuid())
  otp_code   String
  // Wrong-OTP counter; the record is invalidated once it reaches the cap.
  attempts   Int       @default(0)
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("email_changes")
}

model PasswordReset {
  id              String    @id @default(uuid()) @db.VarChar(36)
  user_id         String    @db.VarChar(36)
  link_token_hash String    @unique // sha256 hex of the UUID sent by email
  otp_code_hash   String // sha256 hex of the 6-digit code
  attempts        Int       @default(0)
  expires_at      DateTime
  used_at         DateTime?
  created_at      DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model RevokedToken {
  jti        String   @id
  expires_at DateTime
  created_at DateTime @default(now())

  @@map("revoked_tokens")
}
